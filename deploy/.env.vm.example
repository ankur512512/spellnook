# Copy to deploy/.env on the VM and fill in. NEVER commit the real .env.
SPELLNOOK_DOMAIN=spellnook.ankur.theworkpc.com

# Postgres (in-container). Use a strong password.
POSTGRES_USER=spellnook
POSTGRES_PASSWORD=
POSTGRES_DB=spellnook

# Signs our session JWTs. Generate: openssl rand -hex 32
SPELLNOOK_JWT_SECRET=

# Optional: Google sign-in (see docs/AUTH_SETUP.md). Add the SAME id for FE+BE.
# Remember to add https://spellnook.ankur.theworkpc.com as an authorized origin.
GOOGLE_CLIENT_ID=

# Same-origin behind Caddy => leave empty.
CORS_ALLOW_ORIGINS=
