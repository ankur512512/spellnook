# Copy to `.env` (local/staging) or `.env.prod` (production) and fill in.
# docker-compose auto-reads `.env`; for prod use: docker compose --env-file .env.prod ...
# NEVER commit real secrets. .env* is git-ignored.

# --- Auth (optional in dev; required for Google sign-in) ---
# Same OAuth Client ID for backend + frontend. See docs/AUTH_SETUP.md.
GOOGLE_CLIENT_ID=

# Secret used to sign our own session JWTs. Generate: openssl rand -hex 32
SPELLNOOK_JWT_SECRET=

# --- Production-only (docker-compose.prod.yml) ---
# Postgres credentials (prod). In real prod prefer a managed DB + secrets manager.
POSTGRES_USER=spellnook
POSTGRES_PASSWORD=
POSTGRES_DB=spellnook

# Comma-separated allowed CORS origins. Leave empty if frontend+API are same-origin
# (default behind nginx). Example: https://play.spellnook.com
CORS_ALLOW_ORIGINS=
