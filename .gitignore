# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/

# Node
node_modules/
frontend/dist/
.vite/

# Build artifacts (unused by our Docker builds, which COPY only package.json + npm install)
frontend/package-lock.json
frontend/tsconfig.tsbuildinfo

# Generated word lists (fetched at build time)
backend/app/data/allowed.txt
backend/app/data/allowed_*.txt
backend/app/data/answers_*.txt

# Env (never commit real secrets; *.example templates ARE committed)
.env
.env.*
!.env.example
!.env.vm.example
